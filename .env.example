# ─────────────────────────────────────────────────────────────
# Models (Ollama — single account, OpenAI-compatible endpoint)
# ─────────────────────────────────────────────────────────────
LLM_MODEL=glm-5.2:cloud
VISION_MODEL=qwen3-vl:235b-cloud
EMBED_MODEL=embeddinggemma
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com

# ─────────────────────────────────────────────────────────────
# Database (Supabase Postgres — use the POOLED connection string
# for serverless, not the direct connection)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=

# ─────────────────────────────────────────────────────────────
# Supabase (Auth + Storage + RLS) — new API key format
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=    # sb_publishable_...
SUPABASE_SECRET_KEY=                     # sb_secret_... (server only)

# ─────────────────────────────────────────────────────────────
# Lesson configuration knobs (defaults applied if unset — never
# hardcode these in code, read them from config/lesson.ts)
# ─────────────────────────────────────────────────────────────
NUM_OBJECTIVES=auto          # "auto" = model decides from content
MCQS_PER_OBJECTIVE=3
MAX_RETRIES=unlimited        # "unlimited" or an integer
PASS_THRESHOLD=0.7
