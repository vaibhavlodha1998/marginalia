# ─────────────────────────────────────────────────────────────
# Models (Ollama, single account, OpenAI-compatible endpoint)
# ─────────────────────────────────────────────────────────────
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
LLM_MODEL=glm-5.2:cloud             # plan orchestrator (thinking), once per lesson
FAST_MODEL=deepseek-v4-flash        # MCQ authoring, jury, tutors, summary, title
EVAL_MODEL=deepseek-v4-flash        # MCQ evaluation jury
VISION_MODEL=minimax-m3             # figure captioning (vision)

# ─────────────────────────────────────────────────────────────
# Embeddings: Gemini (works anywhere, incl. Vercel) OR local Ollama.
# Set GOOGLE_API_KEY to use Gemini; otherwise the local Ollama is used.
# ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=                     # Google AI Studio key (optional)
GEMINI_EMBED_MODEL=gemini-embedding-001
EMBED_BASE_URL=http://localhost:11434  # local Ollama, used when GOOGLE_API_KEY is unset
EMBED_MODEL=nomic-embed-text        # 768-dim, schema-locked

# ─────────────────────────────────────────────────────────────
# MCQ evaluation jury (gates on evaluator votes)
# ─────────────────────────────────────────────────────────────
EVAL_QUORUM=majority                # majority | all

# ─────────────────────────────────────────────────────────────
# Database (Supabase Postgres)
#   DATABASE_URL  Transaction pooler (port 6543), app queries (serverless)
#   DIRECT_URL    Session pooler / Direct (port 5432), migrations
# ─────────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─────────────────────────────────────────────────────────────
# Supabase (Auth + Storage + RLS), new API key format
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=    # sb_publishable_...
SUPABASE_SECRET_KEY=                     # sb_secret_... (server only)

# ─────────────────────────────────────────────────────────────
# Email (Resend), used as the Supabase custom SMTP password
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=                          # re_...
