# ─────────────────────────────────────────────────────────────
# Models (Ollama — single account, OpenAI-compatible endpoint)
# ─────────────────────────────────────────────────────────────
LLM_MODEL=glm-5.2:cloud             # heavy reasoning (planning, MCQ authoring, summary)
FAST_MODEL=deepseek-v4-flash        # fast, non-thinking tasks (graph, title, plan)
VISION_MODEL=minimax-m3             # multimodal model for figure captioning
EMBED_MODEL=nomic-embed-text        # local Ollama model, must be 768-dim (schema-locked)
EVAL_MODEL=glm-5.2:cloud            # MCQ evaluation jury
EMBED_BASE_URL=http://localhost:11434  # local Ollama for embeddings (cloud has none)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
COPILOTKIT_TELEMETRY_DISABLED=true

# ─────────────────────────────────────────────────────────────
# MCQ evaluation jury
# ─────────────────────────────────────────────────────────────
EVAL_QUORUM=all                     # all | majority
EVAL_PASS_THRESHOLD=0.7

# ─────────────────────────────────────────────────────────────
# Database (Supabase Postgres)
#   DATABASE_URL  — Transaction pooler (port 6543), app queries (serverless)
#   DIRECT_URL    — Session pooler / Direct (port 5432), checkpointer + migrations
# ─────────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─────────────────────────────────────────────────────────────
# Email (Resend) — also used as the Supabase custom SMTP password
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=                          # re_...

# ─────────────────────────────────────────────────────────────
# Supabase (Auth + Storage + RLS) — new API key format
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=    # sb_publishable_...
SUPABASE_SECRET_KEY=                     # sb_secret_... (server only)

# ─────────────────────────────────────────────────────────────
# Lesson configuration knobs (defaults applied if unset — never
# hardcode these in code, read them from config/lesson.ts)
# ─────────────────────────────────────────────────────────────
NUM_OBJECTIVES=auto          # "auto" = model decides from content
MCQS_PER_OBJECTIVE=3
MAX_RETRIES=unlimited        # "unlimited" or an integer
PASS_THRESHOLD=0.7
